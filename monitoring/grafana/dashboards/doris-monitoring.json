{
  "annotations": {
    "list": [{
      "builtIn": 1,
      "datasource": "-- Grafana --",
      "enable": true,
      "hide": true,
      "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts",
      "type": "dashboard"
    }]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "查询数/秒",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [{
        "expr": "rate(mysql_global_status_queries[1m])",
        "legendFormat": "查询速率",
        "refId": "A"
      }],
      "title": "Doris 查询速率 (QPS)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "已连接",
          "refId": "A"
        },
        {
          "expr": "mysql_global_status_threads_running",
          "legendFormat": "运行中",
          "refId": "B"
        }
      ],
      "title": "连接数",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 200}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "mysql_global_status_threads_connected",
        "refId": "A"
      }],
      "title": "当前连接数",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "mysql_global_status_uptime",
        "refId": "A"
      }],
      "title": "运行时间 (秒)",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "decbytes"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "mysql_global_status_bytes_received",
        "refId": "A"
      }],
      "title": "接收字节数",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "decbytes"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "id": 6,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "mysql_global_status_bytes_sent",
        "refId": "A"
      }],
      "title": "发送字节数",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "targets": [
        {
          "expr": "rate(mysql_global_status_com_select[1m])",
          "legendFormat": "SELECT",
          "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_com_insert[1m])",
          "legendFormat": "INSERT",
          "refId": "B"
        },
        {
          "expr": "rate(mysql_global_status_com_update[1m])",
          "legendFormat": "UPDATE",
          "refId": "C"
        },
        {
          "expr": "rate(mysql_global_status_com_delete[1m])",
          "legendFormat": "DELETE",
          "refId": "D"
        }
      ],
      "title": "SQL 操作速率",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "targets": [
        {
          "expr": "rate(mysql_global_status_bytes_received[1m])",
          "legendFormat": "接收",
          "refId": "A"
        },
        {
          "expr": "rate(mysql_global_status_bytes_sent[1m])",
          "legendFormat": "发送",
          "refId": "B"
        }
      ],
      "title": "网络吞吐量 (Bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 9,
      "targets": [{
        "expr": "mysql_global_status_slow_queries",
        "legendFormat": "慢查询",
        "refId": "A"
      }],
      "title": "慢查询数量",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 10,
      "targets": [
        {
          "expr": "mysql_global_status_table_locks_immediate",
          "legendFormat": "立即获取",
          "refId": "A"
        },
        {
          "expr": "mysql_global_status_table_locks_waited",
          "legendFormat": "等待",
          "refId": "B"
        }
      ],
      "title": "表锁统计",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["doris", "monitoring", "crypto-dw"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "Doris 实时监控",
  "uid": "doris-monitoring",
  "version": 1
}
